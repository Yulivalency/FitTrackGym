<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    android:backgroundTint="#FFF8F3">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Live BodyPump"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="#3A1556"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvBadgeOcup"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvBadgeOcup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disponible"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:padding="6dp"
            android:background="@drawable/bg_chip_disponible"
            app:layout_constraintTop_toTopOf="@id/tvNombre"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="10:00–11:00 · Aforo: 5"
            android:textSize="14sp"
            android:textColor="#7F6B8E"
            app:layout_constraintTop_toBottomOf="@id/tvNombre"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ProgressBar
            android:id="@+id/pbOcupacion"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progress="50"
            android:progressDrawable="@drawable/bg_progress_ocupacion"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toBottomOf="@id/tvDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvPorcentaje"/>

        <TextView
            android:id="@+id/tvPorcentaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100% · 5/5"
            android:textSize="12sp"
            android:textColor="#4A1F6D"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/pbOcupacion"
            app:layout_constraintBottom_toBottomOf="@id/pbOcupacion"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>