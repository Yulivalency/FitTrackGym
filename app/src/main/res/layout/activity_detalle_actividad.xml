<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_calendario_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagen + flecha back superpuesta -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

        <!-- Imagen de cabecera -->
        <ImageView
            android:id="@+id/imgActividad"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/img_generic_clase" />

        <ImageView
            android:id="@+id/tvBackDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back_arrow"
            android:shadowColor="#FFFFA040"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="20"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:layout_gravity="top|start"/>

        </FrameLayout>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">


    <!-- Nombre -->
        <TextView
            android:id="@+id/tvNombreDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/live_bodypump"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <!-- Horario + Aforo-->
        <TextView
            android:id="@+id/tvHorarioDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="10:00–11:00 · Aforo: 20"
            android:textSize="14sp"
            android:textColor="@android:color/white" />

        <!--  Título sobre la clase -->
        <TextView
            android:id="@+id/tvSobreTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/sobre_la_clase"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            android:textColor="@android:color/white" />
        <!-- Descripción -->
        <TextView
            android:id="@+id/tvDescripcionDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:textColor="@android:color/white" />
    </LinearLayout>

    </LinearLayout>
</ScrollView>