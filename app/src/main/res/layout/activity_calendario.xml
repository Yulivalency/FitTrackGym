<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/bg_calendario_gradient">

    <ImageView
        android:id="@+id/tvBackCalendario"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ic_back_arrow"
        app:tint="@android:color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTituloClasesColectivas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/clases_colectivas"
        android:textSize="23sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/tvBackCalendario"
        app:layout_constraintTop_toTopOf="@id/tvBackCalendario"
        app:layout_constraintBottom_toBottomOf="@id/tvBackCalendario" />

    <!-- Botón VER RESERVAS en 3D -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardVerReservas"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:cardUseCompatPadding="true"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintTop_toBottomOf="@id/tvBackCalendario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvVerReservas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/btn_historial_reservas"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:background="@drawable/bg_boton_ver_reservas" />
    </androidx.cardview.widget.CardView>

    <!-- NUEVO: Recycler horizontal para los días -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDias"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/cardVerReservas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_dia_calendario" />

    <!-- Lista de actividades del día -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCalendario"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/rvDias"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="10dp"
        tools:listitem="@layout/item_actividad" />

</androidx.constraintlayout.widget.ConstraintLayout>