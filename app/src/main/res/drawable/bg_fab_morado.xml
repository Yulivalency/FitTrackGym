<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- FAB redondito -->
    <corners android:radius="28dp" />

    <!-- Degradado morado premium -->
    <gradient
        android:type="linear"
        android:angle="45"
        android:startColor="#7A1FFF"
        android:endColor="#B430FF" />

    <!-- Un poquito de padding para que el + respire -->
    <padding
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp" />
</shape>