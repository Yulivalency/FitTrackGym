<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="20dp"
    app:cardUseCompatPadding="true"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/fit_background_soft">

        <!-- Nombre de la clase -->
        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Live BodyPump"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@color/fit_text_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvBadge" />

        <!-- CHIP de estado: usamos tus bg_chip_* -->
        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Reservada"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_chip_lleno"
            app:layout_constraintTop_toTopOf="@id/tvNombre"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Horario + aforo -->
        <TextView
            android:id="@+id/tvHorario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="10:00–11:00 · Aforo: 20"
            android:textSize="13sp"
            android:textColor="@color/fit_text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvNombre"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botón ANULAR con el mismo morado degradado que “Ver” -->
        <Button
            android:id="@+id/btnAccion"
            android:layout_width="130dp"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="@string/anular"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:includeFontPadding="false"
            android:background="@drawable/bg_boton_morado"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            app:layout_constraintTop_toBottomOf="@id/tvHorario"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>