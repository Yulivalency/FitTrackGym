<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    card_view:cardCornerRadius="18dp"
    card_view:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="13dp">

        <!-- Nombre -->
        <TextView
            android:id="@+id/tvNombreAdmin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="BodyPump"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/fit_text_primary"
            card_view:layout_constraintTop_toTopOf="parent"
            card_view:layout_constraintStart_toStartOf="parent"
            card_view:layout_constraintEnd_toEndOf="parent" />

        <!-- Horario -->
        <TextView
            android:id="@+id/tvHorarioAdmin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="10:00–11:00 · Aforo: 20"
            android:textSize="13sp"
            android:textColor="@color/fit_text_secondary"
            card_view:layout_constraintTop_toBottomOf="@id/tvNombreAdmin"
            card_view:layout_constraintStart_toStartOf="parent"
            card_view:layout_constraintEnd_toEndOf="parent" />

        <!-- Botón EDITAR morado degradado -->

        <!-- Texto BORRAR en rojo -->

        <Button
            android:id="@+id/btnEditarAdmin"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/editar"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:gravity="center"
            android:textStyle="bold"
            android:paddingHorizontal="20dp"
            android:paddingVertical="4dp"
            android:includeFontPadding="false"
            android:background="@drawable/bg_boton_morado"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            app:layout_constraintTop_toBottomOf="@id/tvHorarioAdmin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnBorrarAdmin"
            android:layout_marginEnd="20dp" />

        <TextView
            android:id="@+id/btnBorrarAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/borrar"
            android:textSize="14sp"
            android:textColor="#E74C3C"
            card_view:layout_constraintTop_toBottomOf="@id/tvHorarioAdmin"
            card_view:layout_constraintEnd_toEndOf="parent"
            card_view:layout_constraintBottom_toBottomOf="@id/btnEditarAdmin" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>