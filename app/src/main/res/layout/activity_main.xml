<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient"
    tools:context=".MainActivity">

    <!-- Título de la app -->
    <TextView
        android:id="@+id/tvTituloApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FitTrackGym"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="50sp"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Descripción -->

    <!-- Tarjeta blanca del menú -->

    <TextView
        android:id="@+id/tvDescripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:text="@string/reservas_de_clases_recordatorios_y_control_de_aforo_para_tu_gimnasio"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:gravity="center"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/tvTituloApp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/ivDecorCurve"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:srcCompat="@drawable/ic_decor_curve"
        app:tint="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tvDescripcion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/tvDescripcion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="327dp"
            android:layout_height="327dp"
            android:background="@drawable/bg_menu_card"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <!-- FILA 1: Calendario de clases -->
            <LinearLayout
                android:id="@+id/btnCalendario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_menu_icon">

                    <ImageView
                        android:id="@+id/ivCalendario"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/ic_menu_calendar"
                        app:tint="@android:color/white" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvCalendarioClases"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="@string/btn_calendario_text"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:textSize="19sp" />
            </LinearLayout>

            <!-- FILA 2: Mis reservas -->
            <LinearLayout
                android:id="@+id/btnMisReservas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_menu_icon">

                    <ImageView
                        android:id="@+id/ivMisReservas"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/ic_menu_list"
                        app:tint="@android:color/white" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvMisReservas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="@string/mis_reservas"
                    android:textColor="#222222"
                    android:textStyle="bold"
                    android:textSize="19sp" />
            </LinearLayout>

            <!-- FILA 3: Ocupación actual -->
            <LinearLayout
                android:id="@+id/btnOcupacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_menu_icon">

                    <ImageView
                        android:id="@+id/ivOcupacion"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/ic_menu_stats"
                        app:tint="@android:color/white" />
                </FrameLayout>

                <!-- Fila 3: Boton Ocupación -->
                <TextView
                    android:id="@+id/btnOcupacio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="@string/ocupaci_n"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:textSize="19sp" />
            </LinearLayout>

            <!-- FILA 4: Administrar actividades -->
            <LinearLayout
                android:id="@+id/btnAdminActividades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_menu_icon">

                    <ImageView
                        android:id="@+id/ivAdmin"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/ic_menu_settings"
                        app:tint="@android:color/white" />
                </FrameLayout>


                <TextView
                    android:id="@+id/btnAdminActividad"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="@string/admin_actividades"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:textSize="19sp" />
            </LinearLayout>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

        <!-- Enlace pequeño para cargar datos demo (solo para pruebas) -->
            <TextView
                android:id="@+id/tvSeedDemo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_seed_text"
                android:textColor="#9F9F9F"
                android:textSize="13sp"
                android:gravity="center_horizontal"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>

