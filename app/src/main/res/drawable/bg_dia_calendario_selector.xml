<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Seleccionado -->
    <item android:state_selected="true">
        <shape>
            <corners android:radius="24dp" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFFFF" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#FF7A00"
                android:centerColor="#FF3A6B"
                android:endColor="#7A1FFF"/>
        </shape>
    </item>

    <!-- NO seleccionado (también con gradient) -->
    <item>
        <shape>
            <corners android:radius="24dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#FF9A3A"
                android:endColor="#C642FF" />
        </shape>
    </item>

</selector>